# Copy this file to `.env` (same directory, repo root) and fill in your key.
# `.env` is gitignored -- it will NOT be committed. agentic_mpc/agent/llm_config.py loads it
# automatically (no dependency); an explicit `export` in the shell overrides the file.
#
# Default backend is Ollama/qwen3:30b (leave everything below unset to use it).
# To run the controlled model-swap experiment against Claude, set:

AGENTIC_MPC_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
# AGENTIC_MPC_MODEL=claude-sonnet-4-6     # optional; this is the default when backend=anthropic
